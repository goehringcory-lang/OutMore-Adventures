---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import TestimonialCard from '../components/ui/TestimonialCard.astro';
import CtaBand from '../components/sections/CtaBand.astro';

// Sample testimonials — replace with real reviews as they come in
const testimonials = [
  {
    quote: "We've visited Yosemite three times before, but this was the first time we truly saw it. The depth of knowledge and the way every story connected us to something bigger — it was transformative.",
    author: "Sample Guest",
    location: "Reviews will appear here as guests share their experiences",
    rating: 5,
  },
  {
    quote: "I've visited national parks all over the country, but I've never experienced anything like this. The knowledge and passion were extraordinary. This is worth every penny.",
    author: "Sample Guest",
    location: "Reviews will appear here",
    rating: 5,
  },
  {
    quote: "My kids are still talking about it weeks later. They learned more about geology and ecology in one day than in a year of school. This experience changed how our whole family thinks about nature.",
    author: "Sample Guest",
    location: "Reviews will appear here",
    rating: 5,
  },
  {
    quote: "I came to Yosemite expecting beautiful scenery. I left with an understanding of place that I didn't know was possible. This isn't a tour — it's an education and an inspiration.",
    author: "Sample Guest",
    location: "Reviews will appear here",
    rating: 5,
  },
  {
    quote: "The small group size made all the difference. We could ask questions, take our time, and really absorb everything. It felt like exploring with a friend who happens to know everything about this place.",
    author: "Sample Guest",
    location: "Reviews will appear here",
    rating: 5,
  },
  {
    quote: "As someone who studies environmental science, I was blown away by the depth and accuracy of the interpretation. This is the gold standard for nature-based experiences.",
    author: "Sample Guest",
    location: "Reviews will appear here",
    rating: 5,
  },
];
---

<BaseLayout
  title="Reviews"
  description="Read what guests say about their OutMore Adventures experience in Yosemite National Park. Real stories from real visitors."
>
  <Hero
    headline="What Our Guests Say"
    subheadline="Real experiences, real connections, real transformations."
    fullHeight={false}
    backgroundImage="/images/heroes/tunnel-view.jpg"
  />

  <!-- Featured Video Testimonial -->
  <section class="py-20 sm:py-24 bg-valley-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.12em] text-alpenglow mb-4">Featured Story</span>
        <h2>Hear It From Our Guests</h2>
      </div>

      <!-- Video Placeholder -->
      <div class="aspect-video rounded-2xl bg-granite-dark flex items-center justify-center">
        <div class="text-center text-granite-mid">
          <svg class="w-20 h-20 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-sm">Video testimonial coming soon</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial Grid -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {testimonials.map(t => (
          <TestimonialCard
            quote={t.quote}
            author={t.author}
            location={t.location}
            rating={t.rating}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- External Reviews -->
  <section class="py-16 bg-valley-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h3 class="mb-6">Find Us On</h3>
      <div class="flex flex-wrap items-center justify-center gap-8">
        <a href="#" class="text-granite-mid hover:text-granite-dark transition-colors font-semibold text-lg">
          TripAdvisor
        </a>
        <span class="text-granite-light">|</span>
        <a href="#" class="text-granite-mid hover:text-granite-dark transition-colors font-semibold text-lg">
          Google Reviews
        </a>
        <span class="text-granite-light">|</span>
        <a href="#" class="text-granite-mid hover:text-granite-dark transition-colors font-semibold text-lg">
          Yelp
        </a>
      </div>
      <p class="text-granite-mid text-sm mt-4">Review links will be added as they become available</p>
    </div>
  </section>

  <CtaBand
    headline="Ready for Your Own Experience?"
    subtext="Join us for a day that will change how you see Yosemite."
    ctaText="Book Now"
    ctaHref="/book/"
    variant="sequoia"
  />
</BaseLayout>
