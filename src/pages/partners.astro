---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import CtaBand from '../components/sections/CtaBand.astro';
---

<BaseLayout
  title="Partner With Us — Tour Operators & Travel Agents"
  description="OutMore Adventures holds an NPS Commercial Use Authorization for Yosemite. We partner with tour companies, travel agents, and group organizers to deliver authorized Yosemite experiences."
>
  <Hero
    headline="Partner With Yosemite's Authorized Operator"
    subheadline="OutMore Adventures holds a Commercial Use Authorization from the National Park Service. We provide turnkey Yosemite experiences for tour companies, travel agents, and group organizers."
    fullHeight={false}
    backgroundImage="/images/hero/yosemite-valley-bw.jpg"
  />

  <!-- The Regulatory Landscape -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.12em] text-alpenglow mb-4">The Landscape Has Changed</span>
        <h2>The 2026 CUA Shift Changed Everything</h2>
      </div>
      <div class="max-w-3xl mx-auto space-y-6 text-granite-mid text-lg leading-relaxed">
        <p>
          In 2026, the National Park Service redefined how Road-Based Commercial Tour (RBCT) Commercial Use
          Authorizations work in Yosemite. Under the new rules, CUA responsibility shifted from charter bus
          companies to tour operators themselves.
        </p>
        <p>
          Tour companies that previously relied on charter bus operators to hold the CUA can no longer do so.
          Only operators who directly hold a CUA are authorized to conduct commercial tours in the park.
        </p>
        <p class="font-semibold text-granite-dark">
          OutMore Adventures holds its own Commercial Use Authorization directly from the National Park Service.
          We're one of the operators who can legally bring your clients into Yosemite for a guided experience.
        </p>
      </div>
    </div>
  </section>

  <!-- What We Offer Partners -->
  <section class="py-20 sm:py-24 bg-valley-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2>What We Offer Partners</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-sm">
          <div class="w-12 h-12 rounded-full bg-sequoia/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-sequoia" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-granite-dark mb-4">Turnkey Operations</h3>
          <p class="text-granite-mid leading-relaxed">
            We handle everything — NPS-authorized 15-passenger van, certified interpretive guide,
            park entry, and itinerary. Your clients show up; we deliver a world-class experience.
          </p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm">
          <div class="w-12 h-12 rounded-full bg-sequoia/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-sequoia" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </div>
          <h3 class="text-granite-dark mb-4">White-Label Flexibility</h3>
          <p class="text-granite-mid leading-relaxed">
            We can work with your branding, your pickup requirements, and your group logistics.
            Private charters available for groups of any size up to 15.
          </p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm">
          <div class="w-12 h-12 rounded-full bg-sequoia/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-sequoia" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-granite-dark mb-4">Proven Experience</h3>
          <p class="text-granite-mid leading-relaxed">
            20+ years in Yosemite, certified interpretive guide credentials, and a track record
            of five-star experiences. Your clients are in expert hands.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2>How It Works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-merced/10 flex items-center justify-center">
            <span class="text-2xl font-heading font-bold text-merced">1</span>
          </div>
          <h3 class="mb-3">Contact Us</h3>
          <p class="text-granite-mid leading-relaxed">
            Reach out with your group details, preferred dates, and any specific requirements.
            We'll respond within one business day.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-merced/10 flex items-center justify-center">
            <span class="text-2xl font-heading font-bold text-merced">2</span>
          </div>
          <h3 class="mb-3">Custom Itinerary</h3>
          <p class="text-granite-mid leading-relaxed">
            We build a tailored Yosemite experience for your clients — matching their interests,
            fitness levels, and schedule.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-merced/10 flex items-center justify-center">
            <span class="text-2xl font-heading font-bold text-merced">3</span>
          </div>
          <h3 class="mb-3">We Deliver</h3>
          <p class="text-granite-mid leading-relaxed">
            We handle the experience from pickup to drop-off. You deliver happy customers
            and a five-star Yosemite memory.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Inquiry Form -->
  <section class="py-20 sm:py-24 bg-granite-dark relative">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #F5F1EB 1px, transparent 1px); background-size: 60px 60px;"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center mb-12">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.12em] text-golden-grass mb-4">Get Started</span>
        <h2 class="text-white">Partner Inquiry</h2>
        <p class="text-valley-cream/70 text-lg mt-4">
          Tell us about your business and how we can work together.
        </p>
      </div>

      <form name="partner-inquiry" method="POST" data-netlify="true" class="space-y-6">
        <input type="hidden" name="form-name" value="partner-inquiry" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label for="company" class="block text-valley-cream text-sm font-semibold mb-2">Company Name</label>
            <input type="text" id="company" name="company" required class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-golden-grass/50 focus:border-golden-grass/50" placeholder="Your company name" />
          </div>
          <div>
            <label for="contact-name" class="block text-valley-cream text-sm font-semibold mb-2">Contact Name</label>
            <input type="text" id="contact-name" name="contact-name" required class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-golden-grass/50 focus:border-golden-grass/50" placeholder="Your full name" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label for="email" class="block text-valley-cream text-sm font-semibold mb-2">Email</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-golden-grass/50 focus:border-golden-grass/50" placeholder="you@company.com" />
          </div>
          <div>
            <label for="phone" class="block text-valley-cream text-sm font-semibold mb-2">Phone</label>
            <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-golden-grass/50 focus:border-golden-grass/50" placeholder="(555) 123-4567" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label for="business-type" class="block text-valley-cream text-sm font-semibold mb-2">Type of Business</label>
            <select id="business-type" name="business-type" required class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white focus:outline-none focus:ring-2 focus:ring-golden-grass/50 focus:border-golden-grass/50">
              <option value="" class="text-granite-dark">Select your business type</option>
              <option value="tour-company" class="text-granite-dark">Tour Company</option>
              <option value="travel-agent" class="text-granite-dark">Travel Agent</option>
              <option value="dmc" class="text-granite-dark">Destination Management Company</option>
              <option value="corporate" class="text-granite-dark">Corporate Events</option>
              <option value="other" class="text-granite-dark">Other</option>
            </select>
          </div>
          <div>
            <label for="group-size" class="block text-valley-cream text-sm font-semibold mb-2">Estimated Group Size</label>
            <input type="text" id="group-size" name="group-size" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-golden-grass/50 focus:border-golden-grass/50" placeholder="e.g., 10-15 guests" />
          </div>
        </div>

        <div>
          <label for="dates" class="block text-valley-cream text-sm font-semibold mb-2">Preferred Dates or Season</label>
          <input type="text" id="dates" name="dates" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-golden-grass/50 focus:border-golden-grass/50" placeholder="e.g., June-August 2026, or specific dates" />
        </div>

        <div>
          <label for="message" class="block text-valley-cream text-sm font-semibold mb-2">Tell Us About Your Needs</label>
          <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-golden-grass/50 focus:border-golden-grass/50 resize-y" placeholder="Tell us about your clients, what you're looking for, and any questions you have."></textarea>
        </div>

        <div class="text-center pt-4">
          <button type="submit" class="inline-flex items-center px-8 py-4 bg-alpenglow text-white font-body text-sm font-semibold uppercase tracking-[0.08em] rounded hover:bg-alpenglow/90 transition-colors shadow-lg">
            Submit Inquiry
          </button>
          <p class="text-valley-cream/50 text-sm mt-3">We'll respond within one business day.</p>
        </div>
      </form>
    </div>
  </section>

  <!-- CTA -->
  <CtaBand
    headline="Ready to Partner?"
    subtext="Contact us to discuss how OutMore Adventures can serve your Yosemite groups with NPS-authorized experiences."
    ctaText="Email Us Directly"
    ctaHref="mailto:hello@outmoreadventures.com"
    variant="sequoia"
  />
</BaseLayout>
