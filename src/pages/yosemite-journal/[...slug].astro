---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/sections/CtaBand.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('journal');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
>
  <!-- Article Header -->
  <section class="pt-12 pb-8 bg-valley-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/yosemite-journal/" class="inline-flex items-center gap-2 text-sequoia hover:text-sequoia/80 text-sm font-semibold uppercase tracking-[0.06em] mb-8 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Journal
      </a>

      <span class="inline-block text-xs font-semibold uppercase tracking-[0.12em] text-alpenglow mb-4">
        {post.data.category}
      </span>
      <h1 class="mb-4">{post.data.title}</h1>
      <div class="flex items-center gap-4 text-granite-mid text-sm">
        <span>{post.data.author}</span>
        <span>&bull;</span>
        <time>{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <section class="py-12 bg-valley-cream">
    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-lg prose-granite">
      <Content />
    </article>
  </section>

  <!-- Author Bio -->
  <section class="py-12 bg-valley-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl p-8 flex flex-col sm:flex-row items-start gap-6">
        <div class="w-16 h-16 rounded-full bg-granite-light flex items-center justify-center shrink-0">
          <svg class="w-8 h-8 text-granite-mid" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <div>
          <h4 class="text-granite-dark mb-2">{post.data.author}</h4>
          <p class="text-granite-mid text-sm leading-relaxed">
            Written by the team at OutMore Adventures, drawing on over 20 years of experience living in and
            interpreting Yosemite National Park. <a href="/about/" class="text-sequoia hover:underline">Learn more about us.</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    headline="Experience What You've Been Reading About"
    subtext="The stories in the Yosemite Journal come alive on our full-day interpretive experiences."
    ctaText="Book Your Experience"
    ctaHref="/book/"
    variant="sequoia"
  />
</BaseLayout>

<style is:global>
  .prose h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 1.75rem;
    color: #2C3539;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose p {
    color: #8A8D8F;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }

  .prose strong {
    color: #2C3539;
  }

  .prose em {
    color: #8A8D8F;
  }

  .prose a {
    color: #3D5A3E;
    text-decoration: underline;
  }

  .prose a:hover {
    color: #C4663A;
  }

  .prose hr {
    border-color: #D4CFC8;
    margin: 2.5rem 0;
  }

  .prose ul, .prose ol {
    color: #8A8D8F;
  }
</style>
