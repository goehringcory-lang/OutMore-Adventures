---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import CtaBand from '../components/sections/CtaBand.astro';
---

<BaseLayout
  title="Gallery"
  description="Photos and videos from OutMore Adventures experiences in Yosemite National Park. See the park through our eyes."
>
  <Hero
    headline="Gallery"
    subheadline="Yosemite through our eyes — and soon, through yours."
    fullHeight={false}
    backgroundImage="/images/gallery/deer-half-dome.jpg"
  />

  <!-- Photo Gallery -->
  <section class="py-20 sm:py-24 bg-valley-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Category Filters -->
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {['All', 'Valley Views', 'Wildlife', 'Geology', 'Guests', 'Seasons'].map((cat, i) => (
          <button
            class:list={[
              'px-4 py-2 rounded-full text-sm font-semibold transition-colors',
              i === 0
                ? 'bg-sequoia text-white'
                : 'bg-white text-granite-mid hover:text-granite-dark',
            ]}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Photo Grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {[
          { src: '/images/gallery/valley-view.jpg', alt: 'Tunnel View — El Capitan, Bridalveil Fall, and Half Dome', span: true },
          { src: '/images/gallery/deer-half-dome.jpg', alt: 'Mule deer grazing in a meadow beneath Half Dome at alpenglow' },
          { src: '/images/gallery/half-dome.jpg', alt: 'Hikers on the Half Dome cables route' },
          { src: '/images/experience/yosemite-valley.jpg', alt: 'Yosemite Falls reflected in the Merced River' },
          { src: '/images/gallery/merced-river.jpg', alt: 'Clear water of the Merced River with valley walls beyond' },
          { src: '/images/journal/yosemite-falls.jpg', alt: 'El Capitan rising above the Valley floor at golden hour', span: true },
        ].map((img) => (
          <div
            class:list={[
              'rounded-lg overflow-hidden',
              img.span ? 'md:col-span-2 md:row-span-2 aspect-square' : 'aspect-square',
            ]}
          >
            <img src={img.src} alt={img.alt} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
        ))}
      </div>

      <p class="text-center text-granite-mid text-sm mt-8">
        More photos from our experiences coming soon.
      </p>
    </div>
  </section>

  <!-- Video Section -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.12em] text-alpenglow mb-4">Video</span>
        <h2>See the Experience</h2>
      </div>

      <!-- Video Placeholder -->
      <div class="aspect-video rounded-2xl bg-granite-dark flex items-center justify-center">
        <div class="text-center text-granite-mid">
          <svg class="w-20 h-20 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-sm">Video content coming soon</p>
          <p class="text-xs mt-2">YouTube/Vimeo embeds will be placed here</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    headline="Ready to Create Your Own Memories?"
    subtext="Book your OutMore Adventures experience and see Yosemite through new eyes."
    ctaText="Book Your Experience"
    ctaHref="/book/"
    variant="sequoia"
  />
</BaseLayout>
