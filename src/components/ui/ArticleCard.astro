---
interface Props {
  title: string;
  excerpt: string;
  category?: string;
  date?: string;
  slug: string;
  image?: string;
}

const { title, excerpt, category, date, slug, image } = Astro.props;
---

<article class="group">
  <a href={`/yosemite-journal/${slug}/`} class="block">
    <!-- Image -->
    <div class="aspect-[3/2] rounded-lg overflow-hidden mb-4 bg-granite-light">
      {image ? (
        <img
          src={image}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-granite-mid">
          <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      )}
    </div>

    <!-- Content -->
    {category && (
      <span class="inline-block text-xs font-semibold uppercase tracking-[0.08em] text-alpenglow mb-2">
        {category}
      </span>
    )}
    <h3 class="text-granite-dark group-hover:text-sequoia transition-colors mb-2">
      {title}
    </h3>
    <p class="text-granite-mid text-base leading-relaxed line-clamp-2">
      {excerpt}
    </p>
    {date && (
      <time class="block text-granite-mid text-sm mt-3">{date}</time>
    )}
  </a>
</article>
