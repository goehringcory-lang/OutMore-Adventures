---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="space-y-3">
  {items.map((item, index) => (
    <details class="group bg-white rounded-lg shadow-sm" name="faq">
      <summary class="flex items-center justify-between cursor-pointer p-6 font-body font-semibold text-granite-dark hover:text-sequoia transition-colors list-none">
        <span class="pr-4">{item.question}</span>
        <svg class="w-5 h-5 text-granite-mid group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>
      <div class="px-6 pb-6 text-granite-mid leading-relaxed">
        <p>{item.answer}</p>
      </div>
    </details>
  ))}
</div>
